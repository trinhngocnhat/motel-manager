# Root .gitignore for Motel Manager

# Android / Gradle
.gradle/
build/
app/build/
**/build/
local.properties
*.iml
*.keystore
*.jks
.idea/
*.log
.DS_Store

# Kotlin / Java
*.class
*.jar
*.war
*.ear
*.apk
*.ap_

# IDE / Editor
.vscode/
*.swp
*~

# Node.js / backend
back-end/node_modules/
back-end/.env*
back-end/.env.local
back-end/.env.development
back-end/.env.production
back-end/.env.test
back-end/dist/
back-end/build/
back-end/out/
back-end/logs/
back-end/debug.log
back-end/npm-debug.log*
back-end/yarn-debug.log*
back-end/yarn-error.log*
back-end/.cache/
back-end/.tmp/
back-end/tmp/
back-end\node_modules
back-end/.eslintcache
back-end/coverage/
back-end/.nyc_output/
back-end/pids/
back-end/*.pid
back-end/*.pid.lock
back-end/uploads/
back-end/temp/
back-end/public/uploads/
back-end/**/*.tsbuildinfo
back-end/.npm/
back-end/.node_repl_history
back-end/.env.backup

# Optional lock files
back-end/package-lock.json
back-end/yarn.lock
back-end/pnpm-lock.yaml
