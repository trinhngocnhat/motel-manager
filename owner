import com.example.managemotel.ui.theme.AppPrimaryBlue
import com.example.managemotel.ui.theme.AppTypography

data class RoomData(val number: String, val status: String, val tenant: String, val hasFurniture: Boolean = false)

@Composable
fun RoomManagementTab(motelName: String?) {
    var showRoomDialog by remember { mutableStateOf(false) }
    var editingRoom by remember { mutableStateOf<RoomData?>(null) }
    
    val initialRooms = if (motelName?.contains("Quận 1") == true) {
        listOf(
            RoomData("101", "Kín", "Nguyễn Văn A", true),
            RoomData("102", "Kín", "Trần Thị B", true),
            RoomData("201", "Kín", "Phạm Văn D", false),
            RoomData("202", "Kín", "Lê Văn C", true),
            RoomData("301", "Trống", "", false)
        )
    } else {
        listOf(
            RoomData("101", "Kín", "Nguyễn Văn Q7", true),
            RoomData("102", "Kín", "Trần Thị X", true),
            RoomData("201", "Trống", "", false),
            RoomData("202", "Kín", "Lê Văn Z", true),
            RoomData("301", "Trống", "", false)
        )
    }

    val rooms = remember(motelName) { mutableStateListOf(*initialRooms.toTypedArray()) }

    if (showRoomDialog) {
        RoomDialog(
            room = editingRoom,
            onDismiss = { showRoomDialog = false },
            onSave = { newRoom ->
                if (editingRoom != null) {
                    val index = rooms.indexOfFirst { it.number == editingRoom!!.number }
                    if (index != -1) rooms[index] = newRoom
                } else {
                    rooms.add(newRoom)
                }
                showRoomDialog = false
            }
        )
    }

    LazyColumn(modifier = Modifier.padding(16.dp), verticalArrangement = Arrangement.spacedBy(12.dp)) {
        item {
            Button(
                onClick = { 
                    editingRoom = null
                    showRoomDialog = true 
                }, 
                modifier = Modifier.fillMaxWidth(), 
                colors = ButtonDefaults.buttonColors(AppPrimaryBlue)
            ) {
                Icon(Icons.Default.Add, contentDescription = null)
                Text("Thêm phòng mới")
            }
        }
        items(rooms) { room ->
            Card(modifier = Modifier.fillMaxWidth(), colors = CardDefaults.cardColors(containerColor = Color.White)) {
                Row(modifier = Modifier.padding(16.dp), verticalAlignment = Alignment.CenterVertically) {
                    Column(modifier = Modifier.weight(1f)) {
                        Row(verticalAlignment = Alignment.CenterVertically) {
                            Text("Phòng ${room.number}", fontWeight = FontWeight.Bold)
                            if (room.hasFurniture) {
                                Spacer(modifier = Modifier.width(8.dp))
                                Badge(containerColor = Color(0xFFE3F2FD), contentColor = AppPrimaryBlue) { Text("Vật tư") }
                            }
                        }
                        Text(
                            text = if(room.status == "Trống") "Trạng thái: Trống" else "Người thuê: ${room.tenant}",
                            fontSize = AppTypography.SizeSmall,
                            color = if(room.status == "Trống") Color(0xFFEF6C00) else Color.Gray
                        )
                    }
                    IconButton(onClick = { 
                        editingRoom = room
                        showRoomDialog = true 
                    }) { 
                        Icon(Icons.Default.Edit, contentDescription = null, tint = Color.Gray) 
                    }
                    IconButton(onClick = { rooms.remove(room) }) { 
                        Icon(Icons.Default.Delete, contentDescription = null, tint = Color.Red) 
                    }
                }
            }
        }
    }
}

@Composable
fun RoomDialog(room: RoomData?, onDismiss: () -> Unit, onSave: (RoomData) -> Unit) {
    var number by remember { mutableStateOf(room?.number ?: "") }
    var tenant by remember { mutableStateOf(room?.tenant ?: "") }
    var hasFurniture by remember { mutableStateOf(room?.hasFurniture ?: false) }
    var status by remember { mutableStateOf(room?.status ?: "Trống") }

    Dialog(onDismissRequest = onDismiss) {
        Card(
            modifier = Modifier.fillMaxWidth().padding(16.dp),
            shape = RoundedCornerShape(16.dp),
            colors = CardDefaults.cardColors(containerColor = Color.White)
        ) {
            Column(
                modifier = Modifier.padding(16.dp),
                verticalArrangement = Arrangement.spacedBy(12.dp)
            ) {
                Text(
                    text = if (room == null) "Thêm phòng mới" else "Chỉnh sửa phòng",
                    style = MaterialTheme.typography.titleLarge,
                    fontWeight = FontWeight.Bold
                )
                
                OutlinedTextField(
                    value = number,
                    onValueChange = { number = it },
                    label = { Text("Số phòng") },
                    modifier = Modifier.fillMaxWidth()
                )

                Row(verticalAlignment = Alignment.CenterVertically) {
                    Checkbox(checked = hasFurniture, onCheckedChange = { hasFurniture = it })
                    Text("Có vật tư (nội thất)")
                }

                Text("Trạng thái:", fontWeight = FontWeight.SemiBold)
                Row(horizontalArrangement = Arrangement.spacedBy(8.dp)) {
                    FilterChip(
                        selected = status == "Trống",
                        onClick = { status = "Trống"; tenant = "" },
                        label = { Text("Trống") }
                    )
                    FilterChip(
                        selected = status == "Kín",
                        onClick = { status = "Kín" },
                        label = { Text("Đang ở") }
                    )
                }

                if (status == "Kín") {
                    OutlinedTextField(
                        value = tenant,
                        onValueChange = { tenant = it },
                        label = { Text("Tên người thuê") },
                        modifier = Modifier.fillMaxWidth()
                    )
                }

                Row(
                    modifier = Modifier.fillMaxWidth(),
                    horizontalArrangement = Arrangement.End
                ) {
                    TextButton(onClick = onDismiss) { Text("Hủy") }
                    Button(
                        onClick = { onSave(RoomData(number, status, tenant, hasFurniture)) },
                        colors = ButtonDefaults.buttonColors(AppPrimaryBlue)
                    ) {
                        Text("Lưu")
                    }
                }
            }
        }
    }
}
