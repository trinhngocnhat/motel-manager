data class IncidentData(val title: String, val room: String, val date: String, val status: String)

@Composable
fun IncidentTab() {
    var showIncidentDialog by remember { mutableStateOf(false) }
    var editingIncident by remember { mutableStateOf<IncidentData?>(null) }
    
    val incidents = remember { mutableStateListOf(
        IncidentData("Hư bóng đèn", "Phòng 201", "2 giờ trước", "Mới"),
        IncidentData("Nghẹt cống", "Phòng 105", "Hôm qua", "Đã xử lý")
    )}

    if (showIncidentDialog) {
        IncidentDialog(
            incident = editingIncident,
            onDismiss = { showIncidentDialog = false },
            onSave = { newIncident ->
                if (editingIncident != null) {
                    val index = incidents.indexOfFirst { it.title == editingIncident!!.title && it.room == editingIncident!!.room }
                    if (index != -1) incidents[index] = newIncident
                } else {
                    incidents.add(newIncident)
                }
                showIncidentDialog = false
            }
        )
    }

    LazyColumn(modifier = Modifier.padding(16.dp), verticalArrangement = Arrangement.spacedBy(12.dp)) {
        item {
            Button(onClick = { editingIncident = null; showIncidentDialog = true }, modifier = Modifier.fillMaxWidth(), colors = ButtonDefaults.buttonColors(AppPrimaryBlue)) {
                Icon(Icons.Default.ReportProblem, contentDescription = null)
                Text("Báo cáo sự cố mới")
            }
        }
        items(incidents) { incident ->
            Card(modifier = Modifier.fillMaxWidth(), colors = CardDefaults.cardColors(containerColor = if(incident.status == "Mới") Color(0xFFFFEBEE) else Color.White)) {
                Row(modifier = Modifier.padding(16.dp), verticalAlignment = Alignment.CenterVertically) {
                    Icon(
                        imageVector = if(incident.status == "Mới") Icons.Default.Warning else Icons.Default.CheckCircle,
                        contentDescription = null,
                        tint = if(incident.status == "Mới") Color.Red else Color(0xFF2E7D32)
                    )
                    Spacer(modifier = Modifier.width(12.dp))
                    Column(modifier = Modifier.weight(1f)) {
                        Text("${incident.title} - ${incident.room}", fontWeight = FontWeight.Bold)
                        Text(incident.date, fontSize = AppTypography.SizeSmall, color = Color.Gray)
                        Badge(containerColor = if(incident.status == "Mới") Color.Red.copy(0.1f) else Color(0xFF2E7D32).copy(0.1f)) {
                            Text(incident.status, color = if(incident.status == "Mới") Color.Red else Color(0xFF2E7D32))
                        }
                    }
                    IconButton(onClick = { editingIncident = incident; showIncidentDialog = true }) { Icon(Icons.Default.Edit, contentDescription = null, tint = Color.Gray) }
                    IconButton(onClick = { incidents.remove(incident) }) { Icon(Icons.Default.Delete, contentDescription = null, tint = Color.Red) }
                }
            }
        }
    }
}

@Composable
fun IncidentDialog(incident: IncidentData?, onDismiss: () -> Unit, onSave: (IncidentData) -> Unit) {
    var title by remember { mutableStateOf(incident?.title ?: "") }
    var room by remember { mutableStateOf(incident?.room ?: "") }
    var status by remember { mutableStateOf(incident?.status ?: "Mới") }

    Dialog(onDismissRequest = onDismiss) {
        Card(modifier = Modifier.fillMaxWidth().padding(16.dp), shape = RoundedCornerShape(16.dp), colors = CardDefaults.cardColors(containerColor = Color.White)) {
            Column(modifier = Modifier.padding(16.dp), verticalArrangement = Arrangement.spacedBy(12.dp)) {
                Text(text = if (incident == null) "Báo cáo sự cố" else "Sửa sự cố", style = MaterialTheme.typography.titleLarge, fontWeight = FontWeight.Bold)
                OutlinedTextField(value = title, onValueChange = { title = it }, label = { Text("Tên sự cố") }, modifier = Modifier.fillMaxWidth())
                OutlinedTextField(value = room, onValueChange = { room = it }, label = { Text("Số phòng") }, modifier = Modifier.fillMaxWidth())
                
                Text("Trạng thái xử lý:", fontWeight = FontWeight.SemiBold)
                Row(horizontalArrangement = Arrangement.spacedBy(8.dp)) {
                    FilterChip(selected = status == "Mới", onClick = { status = "Mới" }, label = { Text("Mới") })
                    FilterChip(selected = status == "Đã xử lý", onClick = { status = "Đã xử lý" }, label = { Text("Đã xử lý") })
                }

                Row(modifier = Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.End) {
                    TextButton(onClick = onDismiss) { Text("Hủy") }
                    Button(onClick = { onSave(IncidentData(title, room, incident?.date ?: "Vừa xong", status)) }, colors = ButtonDefaults.buttonColors(AppPrimaryBlue)) { Text("Lưu") }
                }
            }
        }
    }
}

